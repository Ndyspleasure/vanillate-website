---
import '../styles/global.css';
import { site } from '@data/site';
import SEO from '@components/SEO.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { url } from '@utils/url';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const { title, description, image, noindex } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content={site.googleSiteVerification} />
    <link rel="icon" type="image/png" sizes="32x32" href={url('/favicon-32.png')} />
    <link rel="icon" type="image/png" sizes="64x64" href={url('/favicon-64.png')} />
    <link rel="apple-touch-icon" sizes="180x180" href={url('/apple-touch-icon.png')} />
    <link rel="alternate" type="application/xml" href={url('/sitemap-index.xml')} title="Sitemap" />

    <!-- Anti-flash theme init: harus inline sebelum CSS untuk hindari FOUC -->
    <script is:inline>
      (function () {
        // Tandai bahwa JS aktif, supaya animasi scroll-reveal boleh menyembunyikan
        // elemen dulu. Tanpa JS, class ini absen dan konten tetap tampil.
        document.documentElement.classList.add('js');
        try {
          const stored = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const isDark = stored ? stored === 'dark' : prefersDark;
          if (isDark) document.documentElement.classList.add('dark');
        } catch (_) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <!-- Fonts: preconnect + swap -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <SEO title={title} description={description} image={image} noindex={noindex} />
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:rounded-full focus:bg-amber-500 focus:px-4 focus:py-2 focus:text-ink-950">Lewati ke konten</a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />

    <script>
      // Scroll reveal global: tampilkan elemen .reveal saat masuk viewport.
      const revealEls = document.querySelectorAll<HTMLElement>('.reveal');
      if (revealEls.length) {
        if (!('IntersectionObserver' in window)) {
          revealEls.forEach((el) => el.classList.add('is-visible'));
        } else {
          const io = new IntersectionObserver(
            (entries, obs) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible');
                  obs.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
          );
          revealEls.forEach((el) => io.observe(el));
        }
      }
    </script>
  </body>
</html>
