---
import BaseLayout from '@layouts/BaseLayout.astro';
import Button from '@components/Button.astro';
import BotCard from '@components/BotCard.astro';
import BotComparison from '@components/BotComparison.astro';
import { bots, getFeaturedBot } from '@data/bots';
import { site, homeStats } from '@data/site';
import { url } from '@utils/url';

const featured = getFeaturedBot();
const others = bots.filter((b) => !b.featured);

// Format angka gaya Indonesia (pemisah ribuan titik). Dipakai untuk nilai awal
// stats; animasi hitung-naik di client memakai formatter yang sama.
function formatNum(n: number): string {
  return Math.round(n).toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.');
}

// Langkah onboarding untuk section "Cara Mulai".
const steps = [
  {
    n: '01',
    title: 'Pilih bot',
    desc: 'Tentukan bot yang paling cocok dengan seleramu, pakai kuis singkat atau tabel perbandingan.',
    href: '/pilih',
    cta: 'Ikuti kuis singkat',
    icon: '<path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>',
  },
  {
    n: '02',
    title: 'Undang ke server',
    desc: 'Satu klik lewat Discord. Beri izin yang diminta, dan bot langsung masuk ke servermu.',
    href: '/bots',
    cta: 'Lihat semua bot',
    icon: '<circle cx="12" cy="12" r="10"/><path d="M12 8v8M8 12h8"/>',
  },
  {
    n: '03',
    title: 'Jalankan command',
    desc: 'Ketik command-nya di channel mana pun, dan permainan langsung dimulai. Tanpa setup ribet.',
    href: '/docs',
    cta: 'Buka dokumentasi',
    icon: '<path d="m4 17 6-6-6-6"/><path d="M12 19h8"/>',
  },
];
---

<BaseLayout>
  <!-- HERO -->
  <section class="relative overflow-hidden pt-20 pb-24 md:pt-32 md:pb-32">
    <!-- Aurora signature -->
    <div class="aurora bg-amber-500/30 h-[500px] w-[500px] top-[-100px] left-[10%]" aria-hidden="true"></div>
    <div class="aurora bg-teal-500/20 h-[400px] w-[400px] top-[100px] right-[5%]" style="animation-delay: -6s" aria-hidden="true"></div>

    <div class="container-page relative">
      <p class="eyebrow mb-8 animate-fade-up">Vanillate Studio · Indonesia</p>
      <h1 class="font-display font-semibold tracking-tightest text-[clamp(2.5rem,7vw,5.5rem)] leading-[0.95] max-w-4xl animate-fade-up">
        Discord Bot yang<br />
        <span class="italic text-amber-600 dark:text-amber-500">dirawat</span>, bukan sekadar dirilis.
      </h1>
      <p class="mt-8 max-w-2xl text-lg md:text-xl text-ink-600 dark:text-cream-200/80 leading-relaxed animate-fade-up" style="animation-delay: 0.1s">
        {site.description}
      </p>
      <div class="mt-10 flex flex-wrap gap-3 animate-fade-up" style="animation-delay: 0.2s">
        <Button href="/bots" variant="primary" size="lg">Jelajahi Bot Kami</Button>
        <Button href="/pilih" variant="secondary" size="lg">Bantu Aku Memilih</Button>
      </div>

      <!-- Social proof: angka nyata komunitas, tiap angka diberi penjelasan singkat -->
      <div class="mt-14 animate-fade-up" style="animation-delay: 0.3s">
        <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-ink-500 dark:text-cream-300/50 mb-4">
          Dipercaya komunitas Discord Indonesia
        </p>
        <div class="grid max-w-4xl grid-cols-2 gap-px overflow-hidden rounded-2xl border border-ink-900/10 dark:border-cream-100/10 bg-ink-900/10 dark:bg-cream-100/10 md:grid-cols-4">
          {homeStats.map((s) => (
            <div class="flex flex-col gap-1 bg-cream-50 dark:bg-ink-950 px-4 py-5 sm:px-5">
              <span
                class="font-display text-2xl md:text-[2rem] font-semibold tracking-tightest text-ink-900 dark:text-cream-50 tabular-nums"
                data-count={String(s.num)}
                data-prefix={s.prefix}
                data-suffix={s.suffix}
              >
                {s.prefix + formatNum(s.num) + s.suffix}
              </span>
              <span class="text-sm font-semibold text-ink-800 dark:text-cream-100">{s.label}</span>
              <span class="text-xs text-ink-500 dark:text-cream-300/60 leading-snug">{s.hint}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED BOT -->
  <section class="container-page py-20">
    <div class="mb-10 flex items-end justify-between gap-6 flex-wrap reveal">
      <div>
        <p class="eyebrow mb-3">Highlight</p>
        <h2 class="font-display text-3xl md:text-5xl font-semibold tracking-tightest max-w-xl">
          Bot unggulan kami saat ini.
        </h2>
      </div>
      <a href={url('/bots')} class="text-sm text-ink-700 dark:text-cream-200 hover:text-amber-600 dark:hover:text-amber-400 inline-flex items-center gap-1.5">
        Lihat semua bot
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="grid gap-6 md:grid-cols-2 reveal" style="--reveal-delay: 80ms">
      <BotCard bot={featured} featured />
      {others.map((bot) => <BotCard bot={bot} />)}
    </div>
  </section>

  <!-- CARA MULAI (3 LANGKAH) -->
  <section class="container-page py-20 border-t border-ink-900/10 dark:border-cream-100/10">
    <div class="max-w-3xl mb-14 reveal">
      <p class="eyebrow mb-3">Cara Mulai</p>
      <h2 class="font-display text-3xl md:text-5xl font-semibold tracking-tightest">
        Dari nol ke main, cuma tiga langkah.
      </h2>
      <p class="mt-4 text-lg text-ink-600 dark:text-cream-200/80 leading-relaxed">
        Tidak perlu daftar akun atau setup rumit. Semuanya berjalan langsung di dalam Discord, gratis.
      </p>
    </div>

    <div class="flex flex-col md:flex-row md:items-stretch gap-4 md:gap-3">
      {steps.map((step, i) => (
        <>
          <div
            class="reveal flex-1 rounded-2xl border border-ink-900/10 dark:border-cream-100/10 bg-cream-100/40 dark:bg-ink-900/40 p-7 transition-colors hover:border-amber-500/40"
            style={`--reveal-delay: ${i * 110}ms`}
          >
            <div class="flex items-center justify-between mb-5">
              <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-amber-500/10 text-amber-600 dark:text-amber-400">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={step.icon} />
              </span>
              <span class="font-mono text-3xl font-bold text-ink-900/10 dark:text-cream-100/15 leading-none">{step.n}</span>
            </div>
            <h3 class="font-display text-xl font-semibold tracking-tightest mb-2">{step.title}</h3>
            <p class="text-ink-600 dark:text-cream-200/80 leading-relaxed text-[0.95rem]">{step.desc}</p>
            <a href={url(step.href)} class="group mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-amber-600 dark:text-amber-400">
              {step.cta}
              <svg class="transition-transform group-hover:translate-x-1" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </div>
          {i < steps.length - 1 && (
            <div class="flex items-center justify-center flex-none text-amber-500/50" aria-hidden="true">
              <svg class="rotate-90 md:rotate-0" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 6 6 6-6 6"/></svg>
            </div>
          )}
        </>
      ))}
    </div>
  </section>

  <!-- COMPARISON -->
  <section class="container-page py-20 border-t border-ink-900/10 dark:border-cream-100/10">
    <div class="mb-10 flex items-end justify-between gap-6 flex-wrap reveal">
      <div>
        <p class="eyebrow mb-3">Bandingkan</p>
        <h2 class="font-display text-3xl md:text-5xl font-semibold tracking-tightest max-w-xl">
          Bingung mulai dari mana?
        </h2>
        <p class="mt-4 max-w-xl text-ink-600 dark:text-cream-200/80 leading-relaxed">
          Tiga bot, tiga rasa berbeda. Sandingkan sebentar untuk menemukan yang paling cocok dengan gayamu.
        </p>
      </div>
      <a href={url('/pilih')} class="text-sm text-ink-700 dark:text-cream-200 hover:text-amber-600 dark:hover:text-amber-400 inline-flex items-center gap-1.5">
        Masih ragu? Ikuti kuis singkat
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="reveal" style="--reveal-delay: 80ms">
      <BotComparison />
    </div>
  </section>

  <!-- VALUES -->
  <section class="container-page py-24">
    <div class="max-w-3xl mb-16 reveal">
      <p class="eyebrow mb-3">Prinsip Kami</p>
      <h2 class="font-display text-3xl md:text-5xl font-semibold tracking-tightest">
        Tiga hal yang tidak kami kompromikan.
      </h2>
    </div>

    <div class="grid gap-8 md:grid-cols-3">
      <div class="reveal" style="--reveal-delay: 0ms">
        <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-amber-500/10 text-amber-600 dark:text-amber-400 font-mono text-lg font-bold">01</div>
        <h3 class="font-display text-xl font-semibold mb-2">Kualitas</h3>
        <p class="text-ink-600 dark:text-cream-200/80 leading-relaxed">Setiap fitur diuji, direview, dan disempurnakan sebelum sampai ke pengguna. Kami menolak rilis yang belum siap.</p>
      </div>
      <div class="reveal" style="--reveal-delay: 110ms">
        <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-amber-500/10 text-amber-600 dark:text-amber-400 font-mono text-lg font-bold">02</div>
        <h3 class="font-display text-xl font-semibold mb-2">Stabilitas</h3>
        <p class="text-ink-600 dark:text-cream-200/80 leading-relaxed">Uptime tinggi dan data yang aman. Bot berjalan di infrastruktur pribadi dengan monitoring dan proses pemulihan yang matang.</p>
      </div>
      <div class="reveal" style="--reveal-delay: 220ms">
        <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-amber-500/10 text-amber-600 dark:text-amber-400 font-mono text-lg font-bold">03</div>
        <h3 class="font-display text-xl font-semibold mb-2">Pengalaman</h3>
        <p class="text-ink-600 dark:text-cream-200/80 leading-relaxed">Interaksi yang jelas, respons yang cepat, dan alur permainan yang menyenangkan, dari command pertama hingga endgame.</p>
      </div>
    </div>
  </section>

  <!-- PROSES -->
  <section class="container-page pb-24">
    <div class="rounded-3xl border border-ink-900/10 dark:border-cream-100/10 p-10 md:p-14 reveal">
      <div class="grid gap-10 md:grid-cols-[1fr_1.6fr] items-start">
        <div>
          <p class="eyebrow mb-3">Cara Kami Bekerja</p>
          <h2 class="font-display text-3xl md:text-4xl font-semibold tracking-tightest">
            Rilis adalah garis start, bukan garis finis.
          </h2>
        </div>
        <div class="grid gap-8 sm:grid-cols-3">
          <div>
            <p class="font-mono text-xs text-amber-600 dark:text-amber-500 mb-3">LANGKAH 01</p>
            <h3 class="font-display text-lg font-semibold mb-2">Dengar</h3>
            <p class="text-sm text-ink-600 dark:text-cream-200/80 leading-relaxed">Ide fitur terbaik datang dari pemain. Setiap masukan di server support dan command <span class="font-mono text-[0.85em]">/masukan</span> kami baca.</p>
          </div>
          <div>
            <p class="font-mono text-xs text-amber-600 dark:text-amber-500 mb-3">LANGKAH 02</p>
            <h3 class="font-display text-lg font-semibold mb-2">Bangun</h3>
            <p class="text-sm text-ink-600 dark:text-cream-200/80 leading-relaxed">Fitur dirancang, ditulis, dan diuji sampai layak. Yang belum siap tidak akan kami paksakan rilis.</p>
          </div>
          <div>
            <p class="font-mono text-xs text-amber-600 dark:text-amber-500 mb-3">LANGKAH 03</p>
            <h3 class="font-display text-lg font-semibold mb-2">Rawat</h3>
            <p class="text-sm text-ink-600 dark:text-cream-200/80 leading-relaxed">Setelah rilis, kami pantau, seimbangkan, dan perbaiki. Lalu kembali ke langkah satu. Begitu terus.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA STRIP -->
  <section class="container-page pb-24">
    <div class="rounded-3xl bg-ink-900 dark:bg-ink-900 p-10 md:p-16 relative overflow-hidden reveal">
      <div class="aurora bg-amber-500/20 h-[300px] w-[300px] top-[-50px] right-[-50px]" aria-hidden="true"></div>
      <div class="relative max-w-2xl">
        <h2 class="font-display text-3xl md:text-5xl font-semibold tracking-tightest text-cream-50">
          Punya pertanyaan atau ide?
        </h2>
        <p class="mt-4 text-cream-100/80 text-lg leading-relaxed">
          Gabung ke server Discord Support kami. Tim Vanillate aktif menjawab, menerima laporan bug, dan berdiskusi dengan komunitas.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={site.links.discordSupport} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-full bg-amber-500 text-ink-950 px-6 py-3 font-medium hover:bg-amber-400 transition-colors">
            Gabung Discord Support
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7M17 7H8M17 7v9" /></svg>
          </a>
          <a href={url('/support')} class="inline-flex items-center rounded-full border border-cream-100/20 text-cream-100 px-6 py-3 font-medium hover:bg-cream-100/5 transition-colors">
            Kunjungi halaman Support
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Animasi hitung-naik untuk angka stats. Angka final sudah ter-render di HTML
  // (aman tanpa JS); script ini menghidupkannya saat masuk viewport.
  function formatNum(n: number): string {
    return Math.round(n).toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.');
  }

  const counters = Array.from(document.querySelectorAll<HTMLElement>('[data-count]'));
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function render(el: HTMLElement, value: number) {
    const prefix = el.dataset.prefix || '';
    const suffix = el.dataset.suffix || '';
    el.textContent = prefix + formatNum(value) + suffix;
  }

  function animate(el: HTMLElement) {
    const target = parseInt(el.dataset.count || '0', 10);
    if (reduced || !Number.isFinite(target)) {
      render(el, target);
      return;
    }
    const duration = 1400;
    const start = performance.now();
    function tick(now: number) {
      const p = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - p, 3); // easeOutCubic
      render(el, target * eased);
      if (p < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  if (counters.length) {
    // Reset ke 0 dulu (kecuali reduced motion) supaya tidak ada lompatan final→0.
    if (!reduced) counters.forEach((el) => render(el, 0));

    if (!('IntersectionObserver' in window)) {
      counters.forEach((el) => animate(el));
    } else {
      const io = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              animate(entry.target as HTMLElement);
              obs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.4 },
      );
      counters.forEach((el) => io.observe(el));
    }
  }
</script>
