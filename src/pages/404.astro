---
import BaseLayout from '@layouts/BaseLayout.astro';
import Button from '@components/Button.astro';
---

<BaseLayout title="Halaman tidak ditemukan" noindex>
  <section class="container-page py-32 text-center">
    <p class="font-mono text-sm text-amber-600 dark:text-amber-500 mb-4">404</p>
    <h1 class="font-display text-4xl md:text-6xl font-semibold tracking-tightest mb-4">Halaman tidak ditemukan.</h1>
    <p class="text-lg text-ink-600 dark:text-cream-200/80 max-w-md mx-auto mb-8">
      Sepertinya halaman yang kamu cari tidak ada, atau sudah dipindahkan.
    </p>
    <div class="flex flex-wrap gap-3 justify-center">
      <Button href="/" variant="primary">Kembali ke Beranda</Button>
      <Button href="/bots" variant="secondary">Lihat Bot Kami</Button>
    </div>
  </section>
</BaseLayout>
