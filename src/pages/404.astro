---
import BaseLayout from '@layouts/BaseLayout.astro';
import Button from '@components/Button.astro';
import { url } from '@utils/url';

const destinations = [
  { label: 'Beranda', desc: 'Kembali ke titik awal', href: '/', icon: '<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M9 22V12h6v10"/>' },
  { label: 'Bot Kami', desc: 'Jelajahi semua bot', href: '/bots', icon: '<rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4M8 16h.01M16 16h.01"/>' },
  { label: 'Dokumentasi', desc: 'Panduan & command', href: '/docs', icon: '<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>' },
  { label: 'Support', desc: 'Butuh bantuan?', href: '/support', icon: '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22z"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3M12 17h.01"/>' },
];
---

<BaseLayout title="Halaman tidak ditemukan" noindex>
  <section class="relative overflow-hidden">
    <div class="aurora bg-amber-500/25 h-[400px] w-[400px] top-[-60px] left-1/2 -translate-x-1/2" aria-hidden="true"></div>
    <div class="container-page py-28 md:py-32 text-center relative">
      <p class="font-mono text-sm text-amber-600 dark:text-amber-500 mb-4 animate-fade-up">404</p>
      <h1 class="font-display text-4xl md:text-6xl font-semibold tracking-tightest mb-4 animate-fade-up">Halaman ini tidak ada.</h1>
      <p class="text-lg text-ink-600 dark:text-cream-200/80 max-w-md mx-auto mb-8 animate-fade-up" style="animation-delay: 0.1s">
        Mungkin salah ketik, mungkin sudah kami pindahkan. Kalau kamu yakin harusnya ada sesuatu di sini, kabari kami di server support, kami perbaiki.
      </p>
      <div class="flex flex-wrap gap-3 justify-center animate-fade-up" style="animation-delay: 0.2s">
        <Button href="/" variant="primary">Kembali ke Beranda</Button>
        <Button href="/bots" variant="secondary">Lihat Bot Kami</Button>
      </div>
    </div>
  </section>

  <section class="container-page pb-28">
    <p class="eyebrow text-center mb-6">Atau lanjutkan ke</p>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 max-w-4xl mx-auto">
      {destinations.map((d) => (
        <a href={url(d.href)} class="group flex flex-col items-center text-center gap-3 rounded-2xl border border-ink-900/10 dark:border-cream-100/10 bg-cream-100/40 dark:bg-ink-900/40 p-6 transition-colors hover:border-amber-500/40">
          <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-amber-500/10 text-amber-600 dark:text-amber-400">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={d.icon} />
          </span>
          <div>
            <p class="font-display font-semibold group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">{d.label}</p>
            <p class="text-xs text-ink-500 dark:text-cream-300/60 mt-0.5">{d.desc}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
