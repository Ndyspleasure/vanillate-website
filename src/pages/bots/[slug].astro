---
import BaseLayout from '@layouts/BaseLayout.astro';
import Button from '@components/Button.astro';
import FAQAccordion from '@components/FAQAccordion.astro';
import { bots, buildInviteUrl, inviteCtaLabel, CTA } from '@data/bots';
import { faqs } from '@data/faq';
import { site } from '@data/site';
import { url } from '@utils/url';

export function getStaticPaths() {
  return bots.map((bot) => ({ params: { slug: bot.slug }, props: { bot } }));
}

const { bot } = Astro.props;
const inviteUrl = buildInviteUrl(bot);
const comingSoon = bot.status === 'coming-soon';
const isPreorder = bot.status === 'preorder';
const heroInviteLabel = inviteCtaLabel(bot);
const botFaqs = faqs[bot.slug];
---

<BaseLayout title={bot.seoTitle ?? bot.name} description={bot.seoDescription ?? bot.description}>
  <section class="relative overflow-hidden pt-20 pb-16 md:pt-28">
    <div class="aurora h-[400px] w-[400px] top-[-80px] left-[10%] opacity-30" style={`background: ${bot.color}`} aria-hidden="true"></div>

    <div class="container-page relative">
      <a href={url('/bots')} class="inline-flex items-center gap-1.5 text-sm text-ink-600 dark:text-cream-300 hover:text-amber-600 dark:hover:text-amber-400 mb-8">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Semua bot
      </a>

      <div class="flex items-start gap-4 mb-6">
        {bot.thumbnail ? (
          <img
            src={url(bot.thumbnail)}
            alt=""
            class="h-16 w-16 rounded-2xl object-cover flex-none"
            loading="eager"
            decoding="async"
          />
        ) : (
          <span
            class="flex h-16 w-16 items-center justify-center rounded-2xl text-3xl"
            style={`background: ${bot.color}20; color: ${bot.color};`}
            aria-hidden="true"
          >
            {bot.icon}
          </span>
        )}
        <div>
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-ink-500 dark:text-cream-300/60 mb-1">
            {bot.category}
            {comingSoon && (
              <span class="ml-2 inline-flex items-center gap-1.5 rounded-full bg-amber-500/10 px-2.5 py-0.5 text-[10px] font-mono uppercase tracking-wider text-amber-600 dark:text-amber-500 align-middle">
                <span class="h-1.5 w-1.5 rounded-full bg-amber-500"></span>
                Dalam Pengembangan
              </span>
            )}
            {isPreorder && (
              <span class="ml-2 inline-flex items-center gap-1.5 rounded-full bg-teal-500/10 px-2.5 py-0.5 text-[10px] font-mono uppercase tracking-wider text-teal-600 dark:text-teal-400 align-middle">
                <span class="h-1.5 w-1.5 rounded-full bg-teal-500 animate-pulse"></span>
                Preorder Beta
              </span>
            )}
          </p>
          <h1 class="font-display font-semibold tracking-tightest text-4xl md:text-6xl leading-none">{bot.name}</h1>
        </div>
      </div>

      <p class="max-w-2xl text-lg md:text-xl text-ink-600 dark:text-cream-200/80 leading-relaxed">
        {bot.description}
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        {inviteUrl && (
          <Button href={inviteUrl} variant="primary" size="lg" external>
            {heroInviteLabel}
          </Button>
        )}
        {comingSoon && (
          <Button href={site.links.discordSupport} variant="primary" size="lg" external>
            {CTA.notify}
          </Button>
        )}
        {isPreorder && (
          <Button href={site.links.discordSupport} variant="secondary" size="lg" external>
            {CTA.discord}
          </Button>
        )}
        {bot.docsSlug && (
          <Button href={`/docs/${bot.docsSlug}`} variant="secondary" size="lg">
            {CTA.docs}
          </Button>
        )}
      </div>
      {bot.ctaNote && (
        <p class="mt-3 text-sm text-ink-500 dark:text-cream-300/60 font-mono">{bot.ctaNote}</p>
      )}
    </div>
  </section>

  {bot.longIntro && bot.longIntro.length > 0 && (
    <section class="container-page py-16 border-t border-ink-900/10 dark:border-cream-100/10">
      <div class="grid gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p class="eyebrow mb-3">Dunia {bot.shortName}</p>
          <h2 class="font-display text-3xl md:text-4xl font-semibold tracking-tightest">Seperti apa rasanya.</h2>
        </div>
        <div class="md:col-span-2 max-w-prose space-y-5 text-lg text-ink-700 dark:text-cream-200 leading-relaxed">
          {bot.longIntro.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </section>
  )}

  <!-- FEATURES -->
  <section class="container-page py-16 border-t border-ink-900/10 dark:border-cream-100/10">
    <div class="grid gap-12 md:grid-cols-3">
      <div class="md:col-span-1">
        <p class="eyebrow mb-3">Fitur</p>
        <h2 class="font-display text-3xl md:text-4xl font-semibold tracking-tightest">Apa yang bisa dilakukan.</h2>
      </div>
      <div class="md:col-span-2">
        <ul class="grid gap-4 sm:grid-cols-2">
          {bot.features.map((feature, i) => (
            <li class="flex items-start gap-3 p-4 rounded-xl border border-ink-900/10 dark:border-cream-100/10">
              <span class="mt-0.5 font-mono text-xs text-amber-600 dark:text-amber-500 flex-none">{String(i + 1).padStart(2, '0')}</span>
              <span class="text-ink-700 dark:text-cream-200 leading-relaxed">{feature}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- COMMANDS -->
  {bot.commands && bot.commands.length > 0 && (
    <section class="container-page py-16 border-t border-ink-900/10 dark:border-cream-100/10">
      <div class="grid gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p class="eyebrow mb-3">Perintah Utama</p>
          <h2 class="font-display text-3xl md:text-4xl font-semibold tracking-tightest">Sekilas command.</h2>
          <p class="mt-4 text-ink-600 dark:text-cream-200/80">Daftar lengkap perintah dan opsi tersedia di halaman dokumentasi.</p>
        </div>
        <div class="md:col-span-2 space-y-2">
          {bot.commands.map((cmd) => (
            <div class="flex items-baseline gap-4 p-4 rounded-lg bg-cream-100/60 dark:bg-ink-900/60 border border-ink-900/5 dark:border-cream-100/5">
              <code class="font-mono text-sm text-amber-600 dark:text-amber-400 flex-none">{cmd.name}</code>
              <span class="text-sm text-ink-700 dark:text-cream-200">{cmd.description}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {bot.founding && (
    <section class="container-page py-16 border-t border-ink-900/10 dark:border-cream-100/10">
      <div class="rounded-3xl border border-teal-500/20 bg-teal-500/5 p-8 md:p-12">
        <div class="grid gap-10 md:grid-cols-3">
          <div class="md:col-span-1">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-teal-500/10 px-3 py-1 text-[10px] font-mono uppercase tracking-wider text-teal-600 dark:text-teal-400 mb-4">
              <span class="h-1.5 w-1.5 rounded-full bg-teal-500 animate-pulse"></span>
              Beta Exclusive
            </span>
            <h2 class="font-display text-3xl md:text-4xl font-semibold tracking-tightest">{bot.founding.title}</h2>
            <p class="mt-4 text-ink-600 dark:text-cream-200/80 leading-relaxed">{bot.founding.intro}</p>
          </div>
          <div class="md:col-span-2 space-y-8">
            <div>
              <p class="eyebrow mb-4">Keuntungan</p>
              <ul class="grid gap-3 sm:grid-cols-2">
                {bot.founding.perks.map((perk) => (
                  <li class="flex items-start gap-3 p-4 rounded-xl bg-cream-50/60 dark:bg-ink-950/40 border border-ink-900/10 dark:border-cream-100/10">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#14B8A6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="flex-none mt-0.5" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="text-ink-700 dark:text-cream-200 leading-relaxed text-[0.95rem]">{perk}</span>
                  </li>
                ))}
              </ul>
            </div>
            {bot.founding.requirements && bot.founding.requirements.length > 0 && (
              <div>
                <p class="eyebrow mb-4">Syarat</p>
                <ul class="space-y-2">
                  {bot.founding.requirements.map((req) => (
                    <li class="flex items-start gap-2.5 text-ink-700 dark:text-cream-200 leading-relaxed">
                      <span class="mt-2 h-1 w-1 rounded-full bg-teal-500 flex-none"></span>
                      <span>{req}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
            {bot.founding.footnote && (
              <p class="text-sm text-ink-500 dark:text-cream-300/70 leading-relaxed italic">{bot.founding.footnote}</p>
            )}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- FAQ -->
  {botFaqs && botFaqs.length > 0 && (
    <section id="faq" class="container-page py-16 border-t border-ink-900/10 dark:border-cream-100/10 scroll-mt-24">
      <div class="grid gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p class="eyebrow mb-3">FAQ</p>
          <h2 class="font-display text-3xl md:text-4xl font-semibold tracking-tightest">Pertanyaan yang sering muncul.</h2>
          <p class="mt-4 text-ink-600 dark:text-cream-200/80 leading-relaxed">
            Belum ketemu jawabannya? Tim kami siap membantu di server Discord.
          </p>
        </div>
        <div class="md:col-span-2">
          <FAQAccordion items={botFaqs} />
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="container-page py-20">
    <div class="rounded-3xl p-10 md:p-14 relative overflow-hidden" style={`background: linear-gradient(135deg, ${bot.color}15, transparent);`}>
      <div class="max-w-xl">
        {comingSoon ? (
          <>
            <h2 class="font-display text-3xl md:text-4xl font-semibold tracking-tightest mb-4">{bot.shortName} sedang dimasak.</h2>
            <p class="text-ink-600 dark:text-cream-200/80 text-lg mb-8">Gabung server Discord kami untuk mengikuti progres pengembangan, memberi masukan, dan jadi yang pertama tahu saat rilis.</p>
            <div class="flex flex-wrap gap-3">
              <Button href={site.links.discordSupport} variant="primary" size="lg" external>{CTA.discord}</Button>
              <Button href="/bots" variant="ghost" size="lg">Lihat bot lainnya</Button>
            </div>
          </>
        ) : isPreorder ? (
          <>
            <h2 class="font-display text-3xl md:text-4xl font-semibold tracking-tightest mb-4">Amankan tempatmu sekarang.</h2>
            <p class="text-ink-600 dark:text-cream-200/80 text-lg mb-8">Preorder {bot.shortName} ke server Discord kamu selama masa beta dan nikmati semua keuntungan Founding Members saat rilis resmi.</p>
            <div class="flex flex-wrap gap-3">
              <Button href={inviteUrl} variant="primary" size="lg" external>{CTA.preorder}</Button>
              <Button href={site.links.discordSupport} variant="ghost" size="lg" external>{CTA.discord}</Button>
            </div>
          </>
        ) : (
          <>
            <h2 class="font-display text-3xl md:text-4xl font-semibold tracking-tightest mb-4">Coba {bot.shortName} sekarang.</h2>
            <p class="text-ink-600 dark:text-cream-200/80 text-lg mb-8">Tambahkan ke server Discord kamu. Gratis, tanpa syarat berlangganan.</p>
            <div class="flex flex-wrap gap-3">
              <Button href={inviteUrl} variant="primary" size="lg" external>{CTA.invite}</Button>
              <Button href="/support" variant="ghost" size="lg">Butuh bantuan?</Button>
            </div>
          </>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
