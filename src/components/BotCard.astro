---
import type { Bot } from '@data/bots';
import { buildInviteUrl } from '@data/bots';
import { url } from '@utils/url';

export interface Props {
  bot: Bot;
  featured?: boolean;
}

const { bot, featured = false } = Astro.props;
const inviteUrl = buildInviteUrl(bot);

const statusLabel = {
  live: 'Live',
  beta: 'Beta',
  'coming-soon': 'Segera',
}[bot.status];

const statusClass = {
  live: 'bg-teal-500/10 text-teal-500',
  beta: 'bg-teal-500/10 text-teal-500',
  'coming-soon': 'bg-amber-500/10 text-amber-600 dark:text-amber-500',
}[bot.status];

const dotClass = {
  live: 'bg-teal-500 animate-pulse',
  beta: 'bg-teal-500 animate-pulse',
  'coming-soon': 'bg-amber-500',
}[bot.status];
---

<article
  class:list={[
    'group relative flex flex-col overflow-hidden rounded-2xl border border-ink-900/10 dark:border-cream-100/10 bg-cream-100/40 dark:bg-ink-900/40 backdrop-blur transition-all hover:border-ink-900/20 dark:hover:border-cream-100/20',
    featured ? 'md:col-span-2 p-8 md:p-10' : 'p-6 md:p-8',
  ]}
>
  <!-- Accent bar -->
  <div
    class="absolute inset-x-0 top-0 h-0.5 opacity-70"
    style={`background: linear-gradient(90deg, ${bot.color}00, ${bot.color}, ${bot.color}00);`}
    aria-hidden="true"
  ></div>

  <div class="flex items-start justify-between gap-3 mb-4">
    <div class="flex items-center gap-3">
      {bot.thumbnail ? (
        <img
          src={url(bot.thumbnail.replace(/\.png$/, '-256.png'))}
          alt=""
          class="h-11 w-11 rounded-xl object-cover flex-none"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <span
          class="flex h-11 w-11 items-center justify-center rounded-xl text-xl"
          style={`background: ${bot.color}20; color: ${bot.color};`}
          aria-hidden="true"
        >
          {bot.icon}
        </span>
      )}
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-500 dark:text-cream-300/60">{bot.category}</p>
        <h3 class:list={[featured ? 'text-2xl md:text-3xl' : 'text-xl', 'font-display font-semibold tracking-tightest']}>
          {bot.name}
        </h3>
      </div>
    </div>
    <span class:list={['inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-[10px] font-mono uppercase tracking-wider', statusClass]}>
      <span class:list={['h-1.5 w-1.5 rounded-full', dotClass]}></span>
      {statusLabel}
    </span>
  </div>

  <p class:list={[featured ? 'text-base md:text-lg' : 'text-sm', 'text-ink-600 dark:text-cream-200/80 leading-relaxed mb-6']}>
    {featured ? bot.description : bot.tagline}
  </p>

  {featured && (
    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-8">
      {bot.features.slice(0, 4).map((f) => (
        <li class="flex items-start gap-2 text-sm text-ink-700 dark:text-cream-200">
          <span class="mt-1.5 h-1 w-1 rounded-full flex-none" style={`background: ${bot.color};`}></span>
          <span>{f}</span>
        </li>
      ))}
    </ul>
  )}

  <div class="mt-auto flex flex-wrap items-center gap-2">
    {inviteUrl ? (
      <a
        href={inviteUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-full bg-ink-900 dark:bg-amber-500 text-cream-50 dark:text-ink-950 px-4 py-2 text-sm font-medium hover:-translate-y-0.5 transition-transform"
      >
        Undang {bot.shortName}
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    ) : (
      <a
        href={url(`/bots/${bot.slug}`)}
        class="inline-flex items-center gap-2 rounded-full bg-ink-900 dark:bg-amber-500 text-cream-50 dark:text-ink-950 px-4 py-2 text-sm font-medium hover:-translate-y-0.5 transition-transform"
      >
        Intip {bot.shortName}
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    )}
    {inviteUrl && (
      <a
        href={url(`/bots/${bot.slug}`)}
        class="inline-flex items-center gap-1.5 rounded-full px-4 py-2 text-sm text-ink-700 dark:text-cream-200 hover:bg-ink-900/5 dark:hover:bg-cream-100/5"
      >
        Detail
      </a>
    )}
    {bot.docsSlug && (
      <a
        href={url(`/docs/${bot.docsSlug}`)}
        class="inline-flex items-center gap-1.5 rounded-full px-4 py-2 text-sm text-ink-700 dark:text-cream-200 hover:bg-ink-900/5 dark:hover:bg-cream-100/5"
      >
        Docs
      </a>
    )}
  </div>
</article>
