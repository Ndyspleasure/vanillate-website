---
// Logo Vanillate Studio (PNG, dual-theme).
//
// Cara kerja: render DUA <img> (varian light & dark), lalu CSS menampilkan
// salah satunya mengikuti class `html.dark`, sinkron dengan toggle tema
// website (bukan prefers-color-scheme OS, yang bisa beda dengan toggle).
//
// Retina: setiap slot punya srcset 1x/2x/3x. Browser memilih sesuai
// device pixel ratio. Tinggi dikontrol lewat prop `class` (mis. h-9 md:h-12),
// lebar selalu auto mengikuti aspect ratio.
//
// Pakai:
//   <LogoPNG variant="header" class="h-9 sm:h-10 md:h-12" />   (horizontal)
//   <LogoPNG variant="footer" class="h-10" />                  (horizontal)
//   <LogoPNG variant="vertical" class="h-44 md:h-52" />        (vertikal)
//   <LogoPNG variant="mark" class="h-10" />                    (emblem saja)
import { url } from '@utils/url';

export interface Props {
  variant?: 'header' | 'footer' | 'vertical' | 'mark';
  alt?: string;
  class?: string;
  eager?: boolean; // true untuk logo above-the-fold (header)
}

const {
  variant = 'header',
  alt = 'Vanillate Studio',
  class: className = 'h-10',
  eager = false,
} = Astro.props;

// Peta varian -> folder & basename aset
const SETS: Record<string, { dir: string; base: string }> = {
  header:   { dir: 'horizontal', base: 'header-48px' },
  footer:   { dir: 'horizontal', base: 'footer-40px' },
  vertical: { dir: 'vertical',   base: 'v-220px' },
  mark:     { dir: 'mark',       base: 'original' },
};

const { dir, base } = SETS[variant];

function buildSrcset(theme: 'light' | 'dark') {
  const p = url(`/logos/${dir}/${theme}/${base}`);
  if (variant === 'mark') return `${p}.png`;
  return `${p}.png 1x, ${p}@2x.png 2x, ${p}@3x.png 3x`;
}

const loading = eager ? 'eager' : 'lazy';
---

<span class:list={['logo-slot inline-flex', className]}>
  <img
    src={url(`/logos/${dir}/light/${base}.png`)}
    srcset={buildSrcset('light')}
    alt={alt}
    class="logo-light block h-full w-auto"
    loading={loading}
    decoding="async"
  />
  <img
    src={url(`/logos/${dir}/dark/${base}.png`)}
    srcset={buildSrcset('dark')}
    alt={alt}
    class="logo-dark block h-full w-auto"
    loading={loading}
    decoding="async"
  />
</span>

<style is:global>
  /* Toggle varian logo mengikuti tema website (html.dark) */
  .logo-slot .logo-dark { display: none; }
  html.dark .logo-slot .logo-light { display: none; }
  html.dark .logo-slot .logo-dark { display: block; }
</style>
