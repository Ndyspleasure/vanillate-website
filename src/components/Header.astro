---
import { nav, site } from '@data/site';
import ThemeToggle from './ThemeToggle.astro';
import { url } from '@utils/url';

// Normalisasi current path dengan menghilangkan base prefix supaya comparison
// dengan item.href (yang tanpa prefix) tetap bekerja.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const rawPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const currentPath = base && rawPath.startsWith(base) ? (rawPath.slice(base.length) || '/') : rawPath;
---

<header class="sticky top-0 z-40 backdrop-blur-lg bg-cream-50/70 dark:bg-ink-950/70 border-b border-ink-900/5 dark:border-cream-100/5">
  <div class="container-page flex h-16 items-center justify-between">
    <a href={url('/')} class="group inline-flex items-center gap-2.5" aria-label={site.name}>
      <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-ink-900 text-amber-400 dark:bg-amber-500 dark:text-ink-950 font-display text-lg font-bold leading-none">V</span>
      <span class="font-display text-lg font-semibold tracking-tightest">{site.shortName}</span>
    </a>

    <nav class="hidden md:flex items-center gap-1" aria-label="Navigasi utama">
      {nav.map((item) => {
        const active = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
        return (
          <a
            href={url(item.href)}
            class:list={[
              'px-3 py-2 rounded-full text-sm transition-colors',
              active
                ? 'text-ink-900 dark:text-cream-50 bg-ink-900/5 dark:bg-cream-100/5'
                : 'text-ink-600 dark:text-cream-300 hover:text-ink-900 dark:hover:text-cream-50'
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="flex items-center gap-1">
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Buka menu"
        aria-expanded="false"
        class="md:hidden inline-flex h-10 w-10 items-center justify-center rounded-full text-ink-900 hover:bg-ink-900/5 dark:text-cream-100 dark:hover:bg-cream-100/5"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="md:hidden hidden border-t border-ink-900/5 dark:border-cream-100/5">
    <nav class="container-page py-4 flex flex-col gap-1" aria-label="Navigasi mobile">
      {nav.map((item) => (
        <a
          href={url(item.href)}
          class="px-3 py-2.5 rounded-lg text-sm text-ink-700 dark:text-cream-200 hover:bg-ink-900/5 dark:hover:bg-cream-100/5"
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!open));
  });
</script>
